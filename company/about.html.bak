  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { 'cn-black': '#161616', 'cn-dark': '#191919', 'cn-gray': '#6f6f6f', 'cn-light': '#E5E5E5', 'cn-blue': '#b6e4ef', 'cn-green': '#b9e3c6', 'cn-pink': '#ffcedb', 'cn-bg': '#ffffff' },
          fontFamily: { 'ibm': ['"IBM Plex Sans"', 'sans-serif'], 'ibm-cond': ['"IBM Plex Condensed"', 'sans-serif'], 'roboto': ['"Roboto"', 'sans-serif'] },
          maxWidth: { '8xl': '1400px' }
        }
      }
    }
  </script>
  <style>
    * { box-sizing: border-box; }
    body { font-family: 'Roboto', sans-serif; color: #161616; overflow-x: hidden; }
    .font-ibm { font-family: 'IBM Plex Sans', sans-serif; }
    .font-ibm-cond { font-family: 'IBM Plex Condensed', sans-serif; }
    .star-sep { overflow: hidden; white-space: nowrap; line-height: 1; padding: 0; margin: 0; text-align: center; font-family: 'IBM Plex Condensed', sans-serif; letter-spacing: 0; color: #161616; user-select: none; }
    .star-sep-inner { display: inline-block; white-space: nowrap; }
    .mega-dropdown { opacity: 0; visibility: hidden; transform: translateY(8px); transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s; pointer-events: none; }
    .mega-parent:hover .mega-dropdown, .mega-parent.open .mega-dropdown { opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
    .mobile-menu { transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .mobile-menu.open { transform: translateX(0); }
    html { scroll-behavior: smooth; }
    .section-fade { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
    .section-fade.visible { opacity: 1; transform: translateY(0); }
    .form-input:focus { outline: none; border-color: #161616; box-shadow: 0 0 0 2px rgba(22, 22, 22, 0.1); }
    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s ease; padding: 0 24px; }
    .faq-card.open .faq-content { max-height: 500px; padding: 0 24px 24px; }
    .faq-card.open .faq-chevron { transform: rotate(180deg); }
    .faq-chevron { transition: transform 0.3s ease; }
    .value-card { transition: transform 0.3s ease; }
    .value-card:hover { transform: translateY(-4px); }
    .timeline-dot { width: 16px; height: 16px; border-radius: 50%; background: #161616; border: 3px solid #b9e3c6; }
  </style>
<link rel="stylesheet" href="assets/styles.css">
