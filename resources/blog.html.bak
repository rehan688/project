<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog | Restaurant Industry Insights | ChowNow</title>
  <meta name="description" content="Expert insights, tips, and trends for restaurant owners. Learn how to grow your business with commission-free ordering.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Condensed:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Roboto:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config={theme:{extend:{colors:{'cn-black':'#161616','cn-dark':'#191919','cn-gray':'#6f6f6f','cn-light':'#E5E5E5','cn-blue':'#b6e4ef','cn-green':'#b9e3c6','cn-pink':'#ffcedb','cn-bg':'#ffffff'},fontFamily:{'ibm':['"IBM Plex Sans"','sans-serif'],'ibm-cond':['"IBM Plex Condensed"','sans-serif'],'roboto':['"Roboto"','sans-serif']},maxWidth:{'8xl':'1400px'}}}}
  </script>
  <style>
    *{box-sizing:border-box}body{font-family:'Roboto',sans-serif;color:#161616;overflow-x:hidden}.font-ibm{font-family:'IBM Plex Sans',sans-serif}.font-ibm-cond{font-family:'IBM Plex Condensed',sans-serif}
    .star-sep{overflow:hidden;white-space:nowrap;line-height:1;padding:0;margin:0;text-align:center;font-family:'IBM Plex Condensed',sans-serif;letter-spacing:0;color:#161616;user-select:none;-webkit-user-select:none}.star-sep-inner{display:inline-block;white-space:nowrap}
    .mega-dropdown{opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .25s ease,transform .25s ease,visibility .25s;pointer-events:none}.mega-parent:hover .mega-dropdown,.mega-parent.open .mega-dropdown{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto}
    .mobile-menu{transform:translateX(100%);transition:transform .4s cubic-bezier(.4,0,.2,1)}.mobile-menu.open{transform:translateX(0)}
    html{scroll-behavior:smooth}.pill-new{position:relative}.pill-new::after{content:'NEW';position:absolute;top:-6px;right:-48px;background:#bbefc4;color:#303030;font-size:10px;font-weight:700;letter-spacing:.08em;padding:3px 8px;border-radius:5px;line-height:1}
    .section-fade{opacity:0;transform:translateY(20px);transition:opacity .7s ease-out,transform .7s ease-out}.section-fade.visible{opacity:1;transform:translateY(0)}
    .blog-card{transition:transform .3s ease}.blog-card:hover{transform:translateY(-4px)}.blog-card:hover .blog-card-img img{transform:scale(1.05)}.blog-card-img img{transition:transform .5s ease}
    .category-tag{transition:background-color .2s ease,color .2s ease;cursor:pointer}.category-tag:hover,.category-tag.active{background-color:#161616;color:#fff}
    .faq-content{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s ease;padding:0 24px}.faq-card.open .faq-content{max-height:500px;padding:0 24px 24px}.faq-card.open .faq-chevron{transform:rotate(180deg)}.faq-chevron{transition:transform .3s ease}
  </style>
<link rel="stylesheet" href="assets/styles.css">
</head>
<body class="bg-cn-bg">
  
  <style>
    * { box-sizing: border-box; }
    body { font-family: 'Roboto', sans-serif; color: #161616; overflow-x: hidden; margin: 0; }
    .font-ibm { font-family: 'IBM Plex Sans', sans-serif; }
    .font-ibm-cond { font-family: 'IBM Plex Condensed', sans-serif; }
    .star-sep {
      overflow: hidden; white-space: nowrap; line-height: 1; padding: 0; margin: 0;
      text-align: center; font-family: 'IBM Plex Condensed', sans-serif;
      letter-spacing: 0; color: #161616; user-select: none; -webkit-user-select: none;
    }
    .star-sep-inner { display: inline-block; white-space: nowrap; }
    .mega-dropdown {
      opacity: 0; visibility: hidden; transform: translateY(8px);
      transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
      pointer-events: none;
    }
    .mega-parent:hover .mega-dropdown,
    .mega-parent.open .mega-dropdown {
      opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto;
    }
    .mobile-menu {
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .mobile-menu.open { transform: translateX(0); }
    .pill-link { position: relative; display: inline-block; }
    .pill-link::after {
      content: 'NEW'; position: absolute; top: -8px; right: -52px;
      background: #bbefc4; color: #303030; font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; padding: 3px 8px; border-radius: 5px; line-height: 1;
      white-space: nowrap;
    }
    .faq-chevron { transition: transform 0.3s ease; }
    .nav-link {
      position: relative;
      transition: opacity 0.15s ease;
    }
    .nav-link:hover { opacity: 0.6; }
    .drop-link {
      transition: opacity 0.15s ease;
    }
    .drop-link:hover { opacity: 0.6; }
    #site-header { transition: box-shadow 0.3s ease; }
  </style>
<link rel="stylesheet" href="assets/styles.css">
</head>
