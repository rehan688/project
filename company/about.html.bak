    <!-- Timeline -->
    <section class="section-fade">
      <div class="max-w-8xl mx-auto px-6 lg:px-10 py-12 lg:py-20">
        <div class="text-center mb-14">
          <h2 class="font-ibm text-[36px] sm:text-[44px] lg:text-[52px] font-normal leading-[1.05] tracking-[-0.02em] text-cn-black mb-5">
            Our Journey
          </h2>
        </div>
        <div class="max-w-2xl mx-auto">
          <div class="relative">
            <!-- Vertical line -->
            <div class="absolute left-[7px] top-0 bottom-0 w-[2px] bg-cn-light"></div>

            <!-- 2012 -->
            <div class="relative pl-10 pb-12">
              <div class="absolute left-0 top-1 timeline-dot"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2012</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">Founded in Los Angeles</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">ChowNow launches with a simple idea: restaurants deserve a commission-free alternative to third-party delivery apps.</p>
            </div>

            <!-- 2015 -->
            <div class="relative pl-10 pb-12">
              <div class="absolute left-0 top-1 timeline-dot"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2015</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">1,000th Restaurant Partner</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">Reached our first major milestone as restaurants across the country adopted our commission-free platform.</p>
            </div>

            <!-- 2018 -->
            <div class="relative pl-10 pb-12">
              <div class="absolute left-0 top-1 timeline-dot"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2018</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">Discovery Network Launch</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">Launched the Discovery Network, connecting restaurants to hungry diners across Google, Yelp, and more.</p>
            </div>

            <!-- 2020 -->
            <div class="relative pl-10 pb-12">
              <div class="absolute left-0 top-1 timeline-dot"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2020</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">Pivoting Through Pandemic</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">When restaurants needed us most, we waived fees, launched free tools, and helped partners pivot to takeout and delivery.</p>
            </div>

            <!-- 2023 -->
            <div class="relative pl-10 pb-12">
              <div class="absolute left-0 top-1 timeline-dot"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2023</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">Unified Platform Launch</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">Introduced ordering, marketing, and operations in one unified platform—eliminating the need for multiple tools.</p>
            </div>

            <!-- 2025 -->
            <div class="relative pl-10">
              <div class="absolute left-0 top-1 timeline-dot" style="background: #b9e3c6; border-color: #161616;"></div>
              <div class="font-ibm-cond text-xs font-bold tracking-[0.18em] uppercase text-cn-gray mb-2">2025</div>
              <h3 class="font-roboto text-[20px] font-semibold text-cn-black mb-2">AI-Powered Marketing & Catering</h3>
              <p class="font-roboto text-[15px] text-cn-gray leading-[1.6]">Launched AI-driven segmentation, catering module, QR code ordering, and expanded to 20+ POS integrations.</p>
            </div>
          </div>
        </div>
      </div>
